{
  "gateway": {
    "bind": "127.0.0.1",
    "port": 3000,
    "public_url": "https://example.com",
    "tls": { "enabled": true },
    "auth": { "enabled": true, "mode": "oauth2", "token": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2" }
  },
  "auth": { "mode": "oauth2" },
  "logging": { "level": "info" },
  "skills": { "install": { "allow_unverified": false } },
  "agents": {
    "defaults": {
      "models": {
        "provider": "anthropic",
        "temperature": 0.7,
        "maxTokens": 4096
      },
      "sandbox": { "mode": "strict" }
    },
    "list": [
      {
        "id": "secure-agent",
        "name": "Secure Agent",
        "model": "anthropic/claude-haiku",
        "workspace": "~/.openclaw/workspace/agents/secure-agent",
        "agentDir": "~/.openclaw/workspace/agents/secure-agent",
        "tools": {
          "deny": ["web_search", "web_fetch", "exec", "process"]
        }
      }
    ]
  },
  "heartbeat": { "agent": "claude-haiku", "intervalMinutes": 60 },
  "channels": {
    "whatsapp": { "dmPolicy": "allowlist", "dmAllowlist": ["+1234567890"] },
    "telegram": { "dmPolicy": "allowlist", "groupPolicy": "allowlist" },
    "discord": { "dmPolicy": "allowlist", "groupPolicy": "allowlist" }
  },
  "tools": {
    "shell": { "denylist": ["rm -rf", "curl | sh"] },
    "confirmBeforeExecuting": ["rm", "mv", "chmod"],
    "filesystem": {
      "allowRead": ["~/.openclaw"],
      "allowWrite": ["~/.openclaw/workspace"],
      "deny": ["~/.ssh", "~/.aws", "~/.openclaw/secrets", "~/.gnupg"]
    }
  }
}
